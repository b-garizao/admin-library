{
  "name": "admin-library",
  "version": "0.1.0",
  "type": "module",
  "description": "Librería de componentes",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./components": {
      "import": "./dist/components/index.esm.js",
      "require": "./dist/components/index.js",
      "types": "./dist/components/index.d.ts"
    },
    "./modals": {
      "import": "./dist/modals/index.esm.js",
      "require": "./dist/modals/index.js",
      "types": "./dist/modals/index.d.ts"
    },
    "./libs": {
      "import": "./dist/libs/index.esm.js",
      "require": "./dist/libs/index.js",
      "types": "./dist/libs/index.d.ts"
    },
    "./styles": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "rollup -c",
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "build:fresh": "rm -rf dist && rollup -c"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "dependencies": {
    "@lineiconshq/free-icons": "^1.0.4",
    "@lineiconshq/react-lineicons": "^1.0.5",
    "antd": "^5.0.0",
    "bcrypt-ts": "^5.0.0",
    "clsx": "^2.1.1",
    "lineicons": "^1.3.2",
    "react-router": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "^19.2.14",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "rollup": "^3.0.0",
    "rollup-plugin-dts": "^6.0.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.0.0"
  }
}
